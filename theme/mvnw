#!/bin/sh
# Maven Wrapper — delegates to the committed maven-wrapper.jar.
# Downloads Maven on first run; no system Maven required.
set -e

# Resolve the script's own directory regardless of how it was invoked.
# This mirrors the approach used by the Gradle wrapper.
SCRIPT="$0"
while [ -h "$SCRIPT" ]; do
  ls_out=$(ls -ld "$SCRIPT")
  link=$(expr "$ls_out" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    SCRIPT="$link"
  else
    SCRIPT=$(dirname "$SCRIPT")/"$link"
  fi
done
MAVEN_PROJECTBASEDIR=$(dirname "$SCRIPT")
MAVEN_PROJECTBASEDIR=$(cd "$MAVEN_PROJECTBASEDIR" && pwd)

WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

if [ ! -f "$WRAPPER_JAR" ]; then
  echo "ERROR: $WRAPPER_JAR not found." >&2
  exit 1
fi

exec java \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
