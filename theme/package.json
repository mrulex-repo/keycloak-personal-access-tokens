{
  "name": "@mrulex/keycloak-plugin-pat-theme",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "build": "tsc && vite build",
    "build-keycloak-theme": "pnpm run build && keycloakify build",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build-keycloak-theme"
  },
  "dependencies": {
    "@keycloak/keycloak-account-ui": "^26.0.0",
    "@keycloakify/keycloak-account-ui": "~260502.0.0",
    "@keycloakify/keycloak-ui-shared": "~260502.0.0",
    "@patternfly/patternfly": "^5.4.2",
    "@patternfly/react-core": "^5.4.14",
    "@patternfly/react-icons": "^5.4.2",
    "i18next": "^25.0.0",
    "i18next-fetch-backend": "^6.0.0",
    "keycloakify": "^11.0.0",
    "lodash-es": "^4.17.21",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.0.0",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.8"
  }
}
